{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "event-roster",
  "main": "src/index.ts",
  "workers_dev": true,
  "compatibility_date": "2026-07-21",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "../web/dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  }
}
