{
  "name": "@event-roster/worker",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "bootstrap:remote": "node --import tsx scripts/bootstrap-remote.mts",
    "e2e:prepare": "node --import tsx scripts/prepare-e2e-env.mts",
    "e2e:serve": "wrangler dev --config wrangler.e2e.jsonc --port 8787 --local-protocol https --persist-to .wrangler/e2e-state --show-interactive-dev-session false",
    "secrets:remote": "node --import tsx scripts/configure-secrets-remote.mts",
    "smoke:remote": "node --import tsx scripts/smoke-remote.mts",
    "test": "vitest run",
    "types": "wrangler types"
  },
  "dependencies": {
    "@event-roster/contracts": "workspace:*",
    "@event-roster/domain": "workspace:*",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.31",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@types/node": "^22.20.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
